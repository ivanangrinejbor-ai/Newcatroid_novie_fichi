<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/formula_editor_keyboardview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/button_background"
    android:padding="8dp"
    android:orientation="vertical"
    android:weightSum="10">

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_function" style="@style/FormulaEditorCategoryButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_functions" />
        <Button android:id="@+id/formula_editor_keyboard_object" style="@style/FormulaEditorCategoryButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_object" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_sensors" style="@style/FormulaEditorCategoryButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_device" />
        <Button android:id="@+id/formula_editor_keyboard_logic" style="@style/FormulaEditorCategoryButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_logic" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_data" style="@style/FormulaEditorCategoryButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_data" />
        <Button android:id="@+id/formula_editor_keyboard_string" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_string" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <ImageButton android:id="@+id/formula_editor_keyboard_color_picker" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_color_picker" />
        <ImageButton android:id="@+id/formula_editor_keyboard_copy" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_formula_editor_content_copy" />
        <ImageButton android:id="@+id/formula_editor_keyboard_paste" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_formula_editor_content_paste" />
        <ImageButton android:id="@+id/formula_editor_keyboard_delete" style="@style/FormulaEditorDeleteButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@drawable/ic_input_delete" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="?attr/dividerHorizontal" android:layout_marginVertical="4dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_7" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_7" />
        <Button android:id="@+id/formula_editor_keyboard_8" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_8" />
        <Button android:id="@+id/formula_editor_keyboard_9" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_9" />
        <Button android:id="@+id/formula_editor_keyboard_divide" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_operator_divide" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_4" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_4" />
        <Button android:id="@+id/formula_editor_keyboard_5" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_5" />
        <Button android:id="@+id/formula_editor_keyboard_6" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_6" />
        <Button android:id="@+id/formula_editor_keyboard_mult" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_operator_mult" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_1" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_1" />
        <Button android:id="@+id/formula_editor_keyboard_2" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_2" />
        <Button android:id="@+id/formula_editor_keyboard_3" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_3" />
        <Button android:id="@+id/formula_editor_keyboard_minus" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_operator_minus" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_decimal_mark" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_decimal_mark" />
        <Button android:id="@+id/formula_editor_keyboard_0" style="@style/FormulaEditorNumberButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/number_0" />
        <Button android:id="@+id/formula_editor_keyboard_bracket_open" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_bracket_open" />
        <Button android:id="@+id/formula_editor_keyboard_bracket_close" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_bracket_close" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:orientation="horizontal">
        <Button android:id="@+id/formula_editor_keyboard_plus" style="@style/FormulaEditorSymbolButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_operator_plus" />
        <Button android:id="@+id/formula_editor_keyboard_compute" style="@style/FormulaEditorComputeButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/formula_editor_confirm" />
    </LinearLayout>

    <ImageButton android:id="@+id/formula_editor_keyboard_functional_button_toggle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
</LinearLayout>
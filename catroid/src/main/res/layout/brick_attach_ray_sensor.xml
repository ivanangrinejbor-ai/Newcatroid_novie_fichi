<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <CheckBox android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_attach_ray_layout"
        style="@style/BrickContainer.Threed.Big">

        <include layout="@layout/icon_brick_category_threed" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_attach_ray_name"/>
        <TextView android:id="@+id/brick_attach_ray_name" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine"
            android:text="@string/brick_attach_ray_target"
            app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_attach_ray_obj" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine"
            android:text="@string/brick_attach_ray_offset"
            app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_attach_ray_off_x" style="@style/BrickEditText" />
        <TextView android:id="@+id/brick_attach_ray_off_y" style="@style/BrickEditText" />
        <TextView android:id="@+id/brick_attach_ray_off_z" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine"
            android:text="@string/brick_attach_ray_direction"
            app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_attach_ray_dir_x" style="@style/BrickEditText" />
        <TextView android:id="@+id/brick_attach_ray_dir_y" style="@style/BrickEditText" />
        <TextView android:id="@+id/brick_attach_ray_dir_z" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine"
            android:text="@string/brick_attach_ray_distance"
            app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_attach_ray_dist" style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_rebuild_navmesh_layout"
        style="@style/BrickContainer.Pathfinder.Small">

        <include layout="@layout/icon_brick_category_pathfinder" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/pathfinder_rebuild_navmesh" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>

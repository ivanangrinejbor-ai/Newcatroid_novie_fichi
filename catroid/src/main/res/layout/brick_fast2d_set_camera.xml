<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_fast2d_cam_layout"
        style="@style/BrickContainer.Fast2d.Medium">

        <include layout="@layout/icon_brick_category_fast2d" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/fast2d_set_camera" />

        <TextView style="@style/BrickText.SingleLine" android:text="X" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_fast2d_cam_edit_x" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="Y" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_fast2d_cam_edit_y" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/fast2d_zoom_param" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_fast2d_cam_edit_zoom" style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_set_ai_layout"
        style="@style/BrickContainer.Threed.Big">

        <include layout="@layout/icon_brick_category_look" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_set" />
        <TextView android:id="@+id/brick_ai_obj_id" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_mode" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_mode" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_target" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_target" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_speed" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_speed" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_stop" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_stop" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_range" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_range" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_step" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_step" style="@style/BrickEditText" />

        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_ai_avoid" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_ai_avoid" style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>